<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ================= PERMISSIONS ================= -->

    <!-- Internet (WAJIB untuk Gemini AI) -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Location (kalau fitur lokasi dipakai) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <!-- Notification (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Optional: hanya jika kamu benar-benar butuh cleartext HTTP -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- ================= APPLICATION ================= -->

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Notes"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <!-- ================= SPLASH SCREEN ================= -->
        <activity
            android:name=".splash.SplashActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- ================= ONBOARDING ================= -->
        <activity android:name=".onboarding.WelcomeActivity" />
        <activity android:name=".onboarding.LocationActivity" />
        <activity android:name=".onboarding.LanguageActivity" />

        <!-- ================= MAIN APP ================= -->
        <activity android:name=".home.HomeActivity" />
        <activity android:name=".notes.CreateNoteActivity" />
        <activity android:name=".events.EventsActivity" />
        <activity android:name=".search.SearchActivity" />
        <activity android:name=".calendar.CalendarActivity" />
        <activity android:name=".MainActivity" />

    </application>

</manifest>